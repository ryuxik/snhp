# Secrets
.env
.env.*
!.env.example

# Local editor / agent config
.claude/settings.local.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
build/
dist/

# Virtualenvs
venv/
.venv/
env/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Optuna / Tournament runtime state — these get rebuilt each run.
*.db
*.sqlite
*.sqlite3
!gametheory/evals/*.json

# Runtime artifacts from leaderboard runs — regenerated per run.
leaderboard/results/usage.jsonl

# Operator-console session log — contains real dispute content; never commit.
snhp/dispute_console_log.jsonl

# Daily LLM spend counter — runtime state.
snhp/.daily_llm_usage.json

# Dispute-tool analytics event log — runtime data.
snhp/dispute_events.jsonl

# PAPERSWARM runtime store — sqlite comp DB + hash-chained ledger; rebuilt per run.
paperswarm/data/

# COMPANYSIM per-episode workspaces — nested git repos + agent-written code +
# acceptance tests; REGENERATED by replaying the event log. The publishable
# artifacts (events.jsonl + ledger.jsonl + the episode config) live one level up
# in companysim/episodes/<id>/ and ARE committed. See companysim/SPEC.md
# "Workspace — what is committed vs regenerated".
companysim/episodes/*/workspace/

# Editor / OS noise
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~

# Internal-only strategy / planning docs (never publish to the public repo).
# The whitepaper PRDs and the synthetic_handshake_protocol spec are public;
# anything under SNHP_Whitepaper/ ending in _STRATEGY.md, _INTERNAL.md, or
# starting with INTERNAL_ stays local-only.
SNHP_Whitepaper/*_STRATEGY.md
SNHP_Whitepaper/*_INTERNAL.md
SNHP_Whitepaper/INTERNAL_*

# Cached real-market datasets fetched by snhp/market/data_sources.py
snhp/market/data/

# Claude Code local session state (worktrees, plans, local settings).
# Force-add specific project config (e.g. .claude/launch.json) with `git add -f` if wanted.
.claude/

# Generated F1 fidelity fixtures (regenerated from the Python engine in CI)
core/js/test/fixtures.json
core/js/test/boba_world_fixtures.json
research/swarm/ARTICLE.md
research/swarm/article-images/
research/swarm/results/
research/swarm/ARTICLE2-NOTES.md
research/swarm/ARTICLE2.md
research/swarm/ARTICLE3-NOTES.md
research/swarm/ARTICLE3.md
divorce/cases.jsonl
